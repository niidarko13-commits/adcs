# ============================================================================
        # EXTENDED KALMAN FILTER (EKF) FOR ATTITUDE ESTIMATION
# ============================================================================

class AttitudeEKF:
        """
    Error-state EKF for attitude determination (6-state).
    State vector: [δθ_x, δθ_y, δθ_z, δb_gx, δb_gy, δb_gz]ᵀ

    Nominal states propagated separately:
    - q_nom: quaternion (body w.r.t. inertial)
    - b_g: gyro bias
    """

def __init__(self, config: KalmanFilterConfig):
self.cfg = config

        # Nominal states
self.q_nom = np.array([1.0, 0.0, 0.0, 0.0])  # Identity quaternion [w, x, y, z]
self.b_g = np.array([0.0, 0.0, 0.0])  # Gyro bias

        # Error-state covariance (6×6)
self.P = np.diag([config.P0_att] * 3 + [config.P0_bias] * 3)

        # Measurement history for consistency monitoring
self.innovations_fss = []
self.nis_fss = []
self.fss_update_time = -np.inf
self.mag_update_time = -np.inf
self.filter_state = "INIT"
self.degraded = False

def propagate(self, omega_meas: np.ndarray, dt: float):
        """
        Time update: propagate quaternion and covariance using gyro measurement.

        Args:
            omega_meas: measured angular velocity [rad/s]
            dt: time step
        """
        # Correct gyro measurement for estimated bias
omega_corr = omega_meas - self.b_g

        # Propagate quaternion using quaternion exponential
self.q_nom = self._quat_propagate(self.q_nom, omega_corr, dt)

        # Build F matrix (discrete, simplified)
F = np.eye(6)
F[:3, 3:6] = -dt * np.eye(3)

        # Process noise covariance (Q)
Q = np.diag([self.cfg.q_gyro_noise] * 3 + [self.cfg.q_gyro_bias] * 3)

        # Propagate covariance: P ← F P Fᵀ + Q
self.P = F @ self.P @ F.T + Q

        # Ensure positive definiteness
self.P = (self.P + self.P.T) / 2

def update_vector(self, z_body: np.ndarray, v_ref_inertial: np.ndarray,
                  R: float, sensor_id: str, current_time: float,
                  force_update: bool = False) -> bool:
        """
        Measurement update using a single vector measurement.

        Args:
            z_body: normalized measurement vector in body frame
            v_ref_inertial: reference vector in inertial frame
            R: measurement noise variance
            sensor_id: 'FSS', 'MAG', or 'NADIR'
            current_time: current simulation time
            force_update: bypass time interval check (for imaging recalibration)

        Returns:
            True if update was applied, False if rejected (outlier)
        """
z_body = z_body / np.linalg.norm(z_body + 1e-10)
v_ref_inertial = v_ref_inertial / np.linalg.norm(v_ref_inertial + 1e-10)

        # Predicted measurement using nominal quaternion
        C_nom = self._quat_to_matrix(self.q_nom)
z_pred = C_nom @ v_ref_inertial
        z_pred = z_pred / np.linalg.norm(z_pred + 1e-10)

        # Innovation
        nu = z_body - z_pred

        # Measurement matrix H (linearized for small error angles)
        # For vector measurement: H = [-[z_pred]_×, 0_{3×3}]
H = np.hstack([-self._skew(z_pred), np.zeros((3, 3))])

        # Innovation covariance: S = H P Hᵀ + R
        S = H @ self.P @ H.T + R * np.eye(3)

        # Normalized Innovation Squared (NIS) test
        try:
S_inv = np.linalg.inv(S)
nis = nu.T @ S_inv @ nu
except:
        return False

        # Update rate limiting per sensor
        if sensor_id == "FSS":
update_interval = self.cfg.fss_update_interval
        last_update_time = self.fss_update_time
chi2_threshold = self.cfg.chi2_threshold_fss
elif sensor_id == "MAG":
update_interval = self.cfg.mag_update_interval
        last_update_time = self.mag_update_time
chi2_threshold = self.cfg.chi2_threshold_mag
        else:
update_interval = 10.0
last_update_time = -np.inf
        chi2_threshold = 9.0

        # Check time-based update interval (STRICTLY enforced)
time_since_last = current_time - last_update_time
        if time_since_last < update_interval * 0.95 and not force_update:
        return False

        # Check outlier rejection (chi-squared test)
        if nis > chi2_threshold:
self.degraded = True
            return False

        # MEASUREMENT UPDATE: Kalman gain
K = self.P @ H.T @ S_inv

        # Estimate update
dx = K @ nu

        # Inject error into nominal states
        self._inject_error_state(dx)

        # Covariance update (Joseph form for numerical stability)
I_KH = np.eye(6) - K @ H
self.P = I_KH @ self.P @ I_KH.T + K @ (R * np.eye(3)) @ K.T
self.P = (self.P + self.P.T) / 2  # Ensure symmetry

        # Clamp small eigenvalues to maintain numerical stability
        eigvals, eigvecs = np.linalg.eigh(self.P)
eigvals = np.maximum(eigvals, 1e-10)
self.P = eigvecs @ np.diag(eigvals) @ eigvecs.T

        # Record update time
        if sensor_id == "FSS":
self.fss_update_time = current_time
            self.innovations_fss.append(nu)
            self.nis_fss.append(nis)
elif sensor_id == "MAG":
self.mag_update_time = current_time

        return True

def get_state(self) -> Tuple[np.ndarray, np.ndarray, np.ndarray]:
        """Return estimated quaternion, bias, and covariance"""
        return self.q_nom, self.b_g, self.P

def reset_to_identity(self):
        """Reset to identity attitude (for safe mode)"""
self.q_nom = np.array([1.0, 0.0, 0.0, 0.0])
self.b_g = np.array([0.0, 0.0, 0.0])
self.P = np.diag([self.cfg.P0_att] * 3 + [self.cfg.P0_bias] * 3)
self.filter_state = "INIT"

        # --- Helper methods ---

@staticmethod
def _skew(v: np.ndarray) -> np.ndarray:
        """Skew-symmetric matrix [v]_×"""
        return np.array([
                                [0, -v[2], v[1]],
            [v[2], 0, -v[0]],
            [-v[1], v[0], 0]
                                ])

@staticmethod
def _quat_multiply(q1: np.ndarray, q2: np.ndarray) -> np.ndarray:
        """Quaternion multiplication q1 * q2 (Hamilton convention)"""
w1, x1, y1, z1 = q1
        w2, x2, y2, z2 = q2

        return np.array([
                        w1*w2 - x1*x2 - y1*y2 - z1*z2,
                        w1*x2 + x1*w2 + y1*z2 - z1*y2,
                        w1*y2 - x1*z2 + y1*w2 + z1*x2,
                        w1*z2 + x1*y2 - y1*x2 + z1*w2
                                ])

@staticmethod
def _quat_normalize(q: np.ndarray) -> np.ndarray:
        """Normalize quaternion"""
norm = np.linalg.norm(q)
        return q / (norm + 1e-10)

@staticmethod
def _quat_propagate(q: np.ndarray, omega: np.ndarray, dt: float) -> np.ndarray:
        """
        Propagate quaternion using quaternion exponential (small-angle approximation).
        q_new = q_nom * exp(0.5 * omega * dt)
        """
theta = np.linalg.norm(omega) * dt
        if theta < 1e-6:
        # Small angle approximation: exp(ω*dt) ≈ [1, 0.5*ω*dt]
delta_q = np.array([1, 0.5*omega[0]*dt, 0.5*omega[1]*dt, 0.5*omega[2]*dt])
        else:
axis = omega / np.linalg.norm(omega)
delta_q = np.array([
                   np.cos(theta / 2),
axis[0] * np.sin(theta / 2),
axis[1] * np.sin(theta / 2),
axis[2] * np.sin(theta / 2)
            ])

q_new = AttitudeEKF._quat_multiply(q, delta_q)
        return AttitudeEKF._quat_normalize(q_new)

@staticmethod
def _quat_to_matrix(q: np.ndarray) -> np.ndarray:
        """Convert quaternion to rotation matrix (body to inertial)"""
w, x, y, z = q
        return np.array([
                                [1 - 2*(y**2 + z**2), 2*(x*y - w*z), 2*(x*z + w*y)],
        [2*(x*y + w*z), 1 - 2*(x**2 + z**2), 2*(y*z - w*x)],
        [2*(x*z - w*y), 2*(y*z + w*x), 1 - 2*(x**2 + y**2)]
        ])

def _inject_error_state(self, dx: np.ndarray):
        """Inject error-state into nominal states and reset covariance"""
        # Extract error components
        dtheta = dx[:3]
db_g = dx[3:6]

        # Convert small-angle error to quaternion
theta_mag = np.linalg.norm(dtheta)
        if theta_mag > 1e-6:
axis = dtheta / theta_mag
        delta_q = np.array([
        np.cos(theta_mag / 2),
axis[0] * np.sin(theta_mag / 2),
axis[1] * np.sin(theta_mag / 2),
axis[2] * np.sin(theta_mag / 2)
            ])
                    else:
delta_q = np.array([1, 0.5*dtheta[0], 0.5*dtheta[1], 0.5*dtheta[2]])

        # Inject into nominal quaternion
self.q_nom = self._quat_multiply(self.q_nom, delta_q)
self.q_nom = self._quat_normalize(self.q_nom)

        # Update bias
self.b_g += db_g

        # Reset error-state covariance
self.P = np.diag([self.cfg.P0_att] * 3 + [self.cfg.P0_bias] * 3)


# ============================================================================
        # REACTION WHEEL CONTROLLER WITH PID
# ============================================================================

class ReactionWheelController:
        """
    PID-based attitude controller with reaction wheel actuators.

    Control law:
    τ = -Kp * q_error - Kd * ω_error - Ki * ∫q_error
    """

def __init__(self, config: PIDControlConfig, cubesat: CubeSatConfig):
self.cfg = config
self.sat = cubesat

        # Integral term accumulator
self.integral_error = np.array([0.0, 0.0, 0.0])

        # Reaction wheel angular momentum (N·m·s)
self.h_rw = np.array([0.0, 0.0, 0.0])
self.h_rw_max = cubesat.mass * config.integral_limit * 0.1  # Tuned saturation

        # Controller state
self.control_active = True
self.last_torque = np.array([0.0, 0.0, 0.0])

def compute_torque(self, q_error: np.ndarray, omega: np.ndarray,
                   q_target: np.ndarray = np.array([1, 0, 0, 0]),
recalibration_active: bool = False) -> np.ndarray:
        """
        Compute control torque from attitude error and rate.

        Args:
            q_error: quaternion error [w, x, y, z]
            omega: estimated body rate [rad/s]
            q_target: target attitude quaternion
            recalibration_active: if True, lock gyro during imaging

        Returns:
            control torque [N·m]
        """
        if not self.control_active or recalibration_active:
        return np.array([0, 0, 0])

        # Extract attitude error vector (3 components of quaternion error)
att_error = q_error[1:4]

        # Proportional term
tau_p = -self.cfg.Kp_att * att_error

        # Derivative term (rate feedback)
tau_d = -self.cfg.Kd_att * omega

        # Integral term (bias correction)
self.integral_error += att_error * 0.01  # dt = 0.01s
self.integral_error = np.clip(self.integral_error, -self.cfg.integral_limit, self.cfg.integral_limit)
tau_i = self.cfg.Ki_att * self.integral_error

        # Total torque
tau_cmd = tau_p + tau_d + tau_i

        # Saturation
        tau_mag = np.linalg.norm(tau_cmd)
        if tau_mag > self.cfg.Kp_att:  # Dynamic saturation
tau_cmd = tau_cmd / (tau_mag + 1e-6) * self.cfg.Kp_att * 0.5

self.last_torque = tau_cmd
        return tau_cmd

def desaturate_rw(self, h_rw: np.ndarray) -> np.ndarray:
        """
        Magnetic desaturation: dump excess RW momentum via magnetic torquers.
        h_rw: current RW momentum

        Returns:
            magnetic torque for desaturation
        """
h_mag = np.linalg.norm(h_rw)
threshold = self.h_rw_max * self.cfg.integral_limit

        if h_mag > threshold:
tau_desat = -0.0001 * h_rw  # Weak desaturation torque
            return tau_desat
        return np.array([0, 0, 0])


