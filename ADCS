        # ORBITAL ENVIRONMENT & REFERENCE VECTORS
# ============================================================================

class OrbitalEnvironment:
        """
    Generates reference vectors (sun, magnetic field, nadir) for current orbit position.
    Loads precomputed aerodynamic torque from CSV.
    """

def __init__(self, cubesat: CubeSatConfig, aero_csv_path: str = None):
self.sat = cubesat
self.time = 0.0
self.aero_interp = None
self.orbit_state = None

        # Orbital state [x, y, z, vx, vy, vz] in ECI frame
        self._init_orbit()

        # Load aerodynamic torque data
        if aero_csv_path:
        self._load_aero_torque(aero_csv_path)

def _init_orbit(self):
        """Initialize circular SSO orbit at 500 km"""
r_orbit = self.sat.earth_radius + self.sat.altitude
        v_orbit = np.sqrt(self.sat.mu_earth / r_orbit)

        # Start at equator, longitude 0
x = r_orbit
        y = 0
z = 0
vx = 0
vy = v_orbit
        vz = 0

self.orbit_state = np.array([x, y, z, vx, vy, vz])

def _load_aero_torque(self, csv_path: str):
        """Load precomputed aerodynamic torque from CSV"""
        try:
df = pd.read_csv(csv_path)
t_days = df['t_days'].values
        tau_x = df['tau_x_Nm'].values
tau_y = df['tau_y_Nm'].values
        tau_z = df['tau_z_Nm'].values

            # Convert to seconds
        t_sec = t_days * 86400

            # Create interpolation functions
self.aero_interp = {
        'x': interp1d(t_sec, tau_x, kind='linear', bounds_error=False, fill_value='extrapolate'),
                'y': interp1d(t_sec, tau_y, kind='linear', bounds_error=False, fill_value='extrapolate'),
                'z': interp1d(t_sec, tau_z, kind='linear', bounds_error=False, fill_value='extrapolate'),
            }
except Exception as e:
print(f"Warning: Could not load aero torque: {e}")
self.aero_interp = None

def get_sun_vector(self, time: float) -> np.ndarray:
        """Get unit sun vector in inertial frame (simplified)"""
        # Sun moves ~1° per day, approximate as fixed during short simulation
sun_angle = time * 2 * np.pi / 86400  # 1 rotation per day
        return np.array([np.cos(sun_angle), np.sin(sun_angle), 0.1])

def get_magnetic_field(self, pos_eci: np.ndarray) -> np.ndarray:
        """Get magnetic field in inertial frame (dipole model)"""
        # Earth's magnetic moment (rough dipole, pointing north)
m = np.array([0, 0, 7.91e22])  # A·m²
mu0 = 4 * np.pi * 1e-7

r_mag = np.linalg.norm(pos_eci)
r_hat = pos_eci / r_mag

        # Dipole field: B = (μ0/4π) * (3(m·r̂)r̂ - m) / r³
m_dot_r = np.dot(m, r_hat)
B = (mu0 / (4 * np.pi)) * (3 * m_dot_r * r_hat - m) / r_mag**3

        return B

def get_nadir_vector(self, pos_eci: np.ndarray) -> np.ndarray:
        """Get nadir (Earth center) vector in inertial frame"""
        return -pos_eci / (np.linalg.norm(pos_eci) + 1e-6)

def get_aero_torque(self, time: float) -> np.ndarray:
        """Get aerodynamic torque from precomputed data"""
        if self.aero_interp is None:
        return np.array([0, 0, 0])

        try:
tau_x = float(self.aero_interp['x'](time))
tau_y = float(self.aero_interp['y'](time))
tau_z = float(self.aero_interp['z'](time))
        return np.array([tau_x, tau_y, tau_z])
except:
        return np.array([0, 0, 0])

def propagate_orbit(self, dt: float):
        """Propagate orbit by simple Kepler step"""
r_orbit = self.sat.earth_radius + self.sat.altitude
        v_orbit = np.sqrt(self.sat.mu_earth / r_orbit)

        # Simple circular orbit: constant angular velocity
        theta = v_orbit / r_orbit * dt

x, y, z, vx, vy, vz = self.orbit_state

        # Rotate in XY plane
cos_t, sin_t = np.cos(theta), np.sin(theta)
self.orbit_state[0] = x * cos_t - y * sin_t
self.orbit_state[1] = x * sin_t + y * cos_t


