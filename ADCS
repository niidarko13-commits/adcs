class SensorSimulator:
        """Simulates real sensor measurements with noise and biases"""

def __init__(self, config: SensorConfig, seed: int = 42):
self.cfg = config
        np.random.seed(seed)

        # Sensor biases (constant)
self.fss_bias = np.random.randn(3) * config.fss_bias
self.gyro_bias = np.random.randn(3) * (config.gyro_bias_stability * 10)
self.mag_bias = np.random.randn(3) * config.mag_accuracy * 0.1

        # Gyro bias drift
self.gyro_bias_walk = np.array([0.0, 0.0, 0.0])

def measure_gyro(self, omega_true: np.ndarray, dt: float) -> np.ndarray:
        """Add noise and bias to true angular velocity"""
        # Gyro bias random walk
self.gyro_bias_walk += np.random.randn(3) * (self.cfg.gyro_bias_stability * np.sqrt(dt))

        # Measurement
        gyro_meas = omega_true + self.gyro_bias + self.gyro_bias_walk
gyro_meas += np.random.randn(3) * self.cfg.gyro_noise

        return gyro_meas

def measure_fss(self, sun_vec_body: np.ndarray) -> np.ndarray:
        """Add noise to fine sun sensor measurement"""
z = sun_vec_body / (np.linalg.norm(sun_vec_body) + 1e-10)
z += np.random.randn(3) * self.cfg.fss_accuracy
        return z / (np.linalg.norm(z) + 1e-10)

def measure_mag(self, mag_vec_body: np.ndarray) -> np.ndarray:
        """Add noise to magnetometer measurement"""
mag_meas = mag_vec_body + np.random.randn(3) * self.cfg.mag_noise + self.mag_bias
        return mag_meas / (np.linalg.norm(mag_meas) + 1e-10)


