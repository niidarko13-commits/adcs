        # Update rates - AGGRESSIVE per PRIORITY 1
fss_update_interval: float = 30.0  # seconds (LOWER end of 30-60s range)
mag_update_interval: float = 2.0  # second

    # Outlier rejection (chi-squared test) - MODERATE threshold
chi2_threshold_fss: float = 12.0  # 4-sigma test (more permissive)
chi2_threshold_mag: float = 12.0


