        # MAIN SIMULATION
# ============================================================================

class CubeSatADCSSimulation:
        """
    Complete CubeSat ADCS simulation with:
    - 6-state error EKF for attitude estimation
    - PID reaction wheel controller
    - Imaging mode with recalibration
    - Aerodynamic and magnetic torques
    """

def __init__(self, config: CubeSatConfig, ekf_cfg: KalmanFilterConfig,
             pid_cfg: PIDControlConfig, sensor_cfg: SensorConfig,
             aero_csv_path: str = None):
self.sat = config
self.env = OrbitalEnvironment(config, aero_csv_path)
self.sensors = SensorSimulator(sensor_cfg)
self.ekf = AttitudeEKF(ekf_cfg)
self.controller = ReactionWheelController(pid_cfg, config)

        # Simulation state
self.time = 0.0
self.dt = 0.01  # 10 ms timestep

        # True state
self.q_true = np.array([1.0, 0.0, 0.0, 0.0])
self.omega_true = np.random.randn(3) * 0.01  # Initial small disturbance
self.h_rw = np.array([0.0, 0.0, 0.0])

        # Operational parameters
self.mode = OperationMode.NORMAL
self.recalibration_time = -np.inf
self.imaging_active = False

        # Logging
self.log = {
        'time': [],
        'q_true': [],
        'q_est': [],
        'omega_true': [],
        'omega_est': [],
        'att_error_angle': [],
        'att_error_3sig': [],
        'rate_error': [],
        'h_rw': [],
        'mode': [],
        'fss_nis': []
        }

def step(self):
        """Execute one simulation timestep"""

        # 1. SENSOR MEASUREMENTS
        # Get reference vectors in inertial frame
sun_inertial = self.env.get_sun_vector(self.time)
mag_inertial = self.env.get_magnetic_field(self.env.orbit_state[:3])
nadir_inertial = self.env.get_nadir_vector(self.env.orbit_state[:3])

        # Rotate to body frame
C = self.ekf._quat_to_matrix(self.q_true)
sun_body = C @ sun_inertial
        mag_body = C @ mag_inertial
nadir_body = C @ nadir_inertial

        # Measure with sensors
        gyro_meas = self.sensors.measure_gyro(self.omega_true, self.dt)
fss_meas = self.sensors.measure_fss(sun_body)
mag_meas = self.sensors.measure_mag(mag_body)

        # 2. EKF TIME UPDATE (always)
        self.ekf.propagate(gyro_meas, self.dt)

        # 3. EKF MEASUREMENT UPDATES
        # FSS update (30-60 second interval)
        self.ekf.update_vector(fss_meas, sun_inertial, self.ekf.cfg.r_fss,
                               "FSS", self.time)

        # Magnetometer update (slower)
        if int(self.time / 1.0) % 10 == 0:
        self.ekf.update_vector(mag_meas, mag_inertial, self.ekf.cfg.r_mag,
                                   "MAG", self.time)

        # 4. OPERATIONAL MODES
        if self.mode == OperationMode.IMAGING:
        self._handle_imaging_mode()

        # 5. CONTROL
        q_est, b_g_est, P_est = self.ekf.get_state()
q_target = np.array([1, 0, 0, 0])  # Nadir pointing
q_error = self._quat_error(q_est, q_target)
omega_est = gyro_meas - b_g_est

        tau_control = self.controller.compute_torque(
        q_error, omega_est, q_target,
        recalibration_active=self.imaging_active
)

        # 6. DISTURBANCE TORQUES
tau_aero = self.env.get_aero_torque(self.time)
tau_mag = np.array([0, 0, 0])  # Magnetic desaturation (optional)

        # 7. DYNAMICS: RW momentum update and attitude propagation
self.h_rw += tau_control * self.dt
        tau_rw = -self.h_rw / self.dt  # Newton's 3rd law

tau_total = tau_control + tau_aero + tau_mag

        # Attitude dynamics: dω/dt = I⁻¹(τ - ω × Iω)
I = np.diag([self.sat.Ixx, self.sat.Iyy, self.sat.Izz])
omega_cross_Iw = np.cross(self.omega_true, I @ self.omega_true)
domega_dt = np.linalg.solve(I, tau_total - omega_cross_Iw)

        # Integrate with RK4
self.omega_true = self.omega_true + domega_dt * self.dt

        # Quaternion dynamics: dq/dt = 0.5 * Ω(ω) * q
self.q_true = self.ekf._quat_propagate(self.q_true, self.omega_true, self.dt)

        # 8. ORBIT PROPAGATION
        self.env.propagate_orbit(self.dt)

        # 9. COMPUTE ERRORS & LOG
        att_error = self._compute_attitude_error(self.q_true, q_est)
rate_error = np.linalg.norm(self.omega_true - omega_est)

        # 3-sigma uncertainty from EKF covariance
        att_uncertainty = np.sqrt(np.diag(P_est)[:3].sum()) * 180 / np.pi

        # 10. LOGGING
        self._log_state(att_error, att_uncertainty, rate_error)

self.time += self.dt

def _handle_imaging_mode(self):
        """
        PRIORITY 2: Recalibration strategy
        - FSS update 5 min before imaging
        - Lock gyro control during capture
        - 3-5 second imaging window
        """
imaging_duration = 5.0  # seconds
        imaging_interval = 300.0  # 5 minutes between captures

        if self.time - self.recalibration_time > imaging_interval:
        # Trigger imaging sequence
self.recalibration_time = self.time
self.imaging_active = True

            # Force FSS update NOW (not waiting for 45-second interval)
sun_inertial = self.env.get_sun_vector(self.time)
C = self.ekf._quat_to_matrix(self.q_true)
sun_body = C @ sun_inertial
        fss_meas = self.sensors.measure_fss(sun_body)

            # Force update regardless of interval
        old_interval = self.ekf.cfg.fss_update_interval
self.ekf.cfg.fss_update_interval = 0.01  # Force immediate
            self.ekf.update_vector(fss_meas, sun_inertial, self.ekf.cfg.r_fss,
                                   "FSS", self.time)
self.ekf.cfg.fss_update_interval = old_interval

        # Lock control during imaging
        if self.time - self.recalibration_time < imaging_duration:
self.controller.control_active = False
self.imaging_active = True
        else:
self.controller.control_active = True
self.imaging_active = False

@staticmethod
def _quat_error(q_est: np.ndarray, q_target: np.ndarray = np.array([1.0, 0.0, 0.0, 0.0])) -> np.ndarray:
        """Compute quaternion error: q_est⁻¹ * q_target"""
q_est_inv = np.array([q_est[0], -q_est[1], -q_est[2], -q_est[3]])
        return AttitudeEKF._quat_multiply(q_est_inv, q_target)

@staticmethod
def _compute_attitude_error(q_true: np.ndarray, q_est: np.ndarray) -> float:
        """Compute attitude error angle in degrees"""
dot_prod = np.dot(q_true, q_est)
dot_prod = np.clip(dot_prod, -1, 1)
error_angle = 2 * np.arccos(np.abs(dot_prod))
        return error_angle * 180 / np.pi

def _log_state(self, att_error: float, att_3sig: float, rate_error: float):
        """Log current state"""
self.log['time'].append(self.time)
self.log['q_true'].append(self.q_true.copy())
q_est, b_g, P = self.ekf.get_state()
self.log['q_est'].append(q_est.copy())
self.log['omega_true'].append(self.omega_true.copy())
self.log['att_error_angle'].append(att_error)
self.log['att_error_3sig'].append(att_3sig)
self.log['rate_error'].append(rate_error)
self.log['h_rw'].append(self.h_rw.copy())
self.log['mode'].append(self.mode.name)
        if self.ekf.nis_fss:
self.log['fss_nis'].append(self.ekf.nis_fss[-1])

def run(self, duration: float):
        """Run simulation for specified duration (seconds)"""
n_steps = int(duration / self.dt)

print(f"Running CubeSat ADCS Simulation...")
print(f"Duration: {duration:.1f} s | Timestep: {self.dt*1000:.1f} ms")
print(f"Total steps: {n_steps}")
print()

        for i in range(n_steps):
        self.step()
            if i % 1000 == 0 and len(self.log['att_error_angle']) > 0:
print(f"  Step {i}/{n_steps} (t={self.time:.1f}s) - "
        f"Att error: {self.log['att_error_angle'][-1]:.3f}°")

print(f"\n✓ Simulation complete at t={self.time:.1f}s")

def get_metrics(self) -> dict:
        """Compute performance metrics"""
att_errors = np.array(self.log['att_error_angle'])
rate_errors = np.array(self.log['rate_error'])

        # Skip first 10% as transient
n_transient = len(att_errors) // 10
att_errors_steady = att_errors[n_transient:]
rate_errors_steady = rate_errors[n_transient:]

        return {
        'att_rms': np.sqrt(np.mean(att_errors_steady ** 2)),
        'att_std': np.std(att_errors_steady),
            'att_max': np.max(att_errors_steady),
            'rate_rms': np.sqrt(np.mean(rate_errors_steady ** 2)),
        'rate_std': np.std(rate_errors_steady),
            'rate_max': np.max(rate_errors_steady),
            'att_3sig_mean': np.mean(np.array(self.log['att_error_3sig'])[n_transient:]),
        }


